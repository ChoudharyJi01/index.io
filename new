<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Abhishek Choudhary | Data Scientist</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#000000;
  --bg1:#080808;
  --bg2:#0f0f0f;
  --bg3:#141414;
  --border:rgba(255,255,255,0.06);
  --border2:rgba(255,255,255,0.1);
  --text:#f0f0f0;
  --muted:#555;
  --muted2:#888;
  --gold:#c9a84c;
  --gold2:#e8c97a;
  --accent:#ffffff;
  --red:#ff3c3c;
  --font:'Syne',sans-serif;
  --body:'DM Sans',sans-serif;
  --mono:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth;cursor:none}
body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--body);
  font-weight:300;
  overflow-x:hidden;
  line-height:1.6;
}

/* ── CUSTOM CURSOR ── */
#cursor{
  position:fixed;width:12px;height:12px;
  background:#fff;border-radius:50%;
  pointer-events:none;z-index:99999;
  transform:translate(-50%,-50%);
  transition:width 0.2s,height 0.2s,background 0.2s,opacity 0.2s;
  mix-blend-mode:difference;
}
#cursor-ring{
  position:fixed;width:36px;height:36px;
  border:1px solid rgba(255,255,255,0.4);
  border-radius:50%;pointer-events:none;z-index:99998;
  transform:translate(-50%,-50%);
  transition:transform 0.12s ease,width 0.3s,height 0.3s,border-color 0.3s;
}
body:has(a:hover) #cursor,body:has(button:hover) #cursor{width:6px;height:6px}
body:has(a:hover) #cursor-ring,body:has(button:hover) #cursor-ring{width:56px;height:56px;border-color:var(--gold)}

/* ── NOISE OVERLAY ── */
body::before{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events:none;z-index:9997;opacity:0.4;
}

/* ── NAVBAR ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.4rem 4rem;
  transition:background 0.4s,padding 0.4s,border-bottom 0.4s;
}
nav.scrolled{
  background:rgba(0,0,0,0.92);
  backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
  padding:1rem 4rem;
}
.nav-logo{
  font-family:var(--font);font-size:1.2rem;font-weight:800;
  letter-spacing:0.06em;color:var(--text);text-decoration:none;
  position:relative;
}
.nav-logo span{color:var(--gold)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{
  font-family:var(--mono);font-size:0.7rem;letter-spacing:0.18em;
  text-transform:uppercase;color:var(--muted2);text-decoration:none;
  transition:color 0.3s;position:relative;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;
  background:var(--gold);transition:width 0.3s ease;
}
.nav-links a:hover{color:var(--text)}
.nav-links a:hover::after{width:100%}
.nav-btn{
  font-family:var(--mono);font-size:0.68rem;letter-spacing:0.15em;
  text-transform:uppercase;padding:0.6rem 1.4rem;
  border:1px solid var(--gold);color:var(--gold);
  background:transparent;text-decoration:none;
  transition:all 0.3s;border-radius:2px;cursor:none;
}
.nav-btn:hover{background:var(--gold);color:#000}

/* ── HERO ── */
#hero{
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:8rem 2rem 4rem;
  position:relative;overflow:hidden;text-align:center;
}
.hero-bg-lines{
  position:absolute;inset:0;pointer-events:none;
  background:
    linear-gradient(rgba(201,168,76,0.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(201,168,76,0.04) 1px,transparent 1px);
  background-size:80px 80px;
  animation:gridDrift 20s linear infinite;
}
@keyframes gridDrift{from{background-position:0 0}to{background-position:80px 80px}}
.hero-vignette{
  position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 70% at 50% 50%,transparent 30%,#000 100%);
}
.hero-orb{
  position:absolute;width:500px;height:500px;border-radius:50%;
  background:radial-gradient(circle,rgba(201,168,76,0.08) 0%,transparent 70%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;animation:orbPulse 6s ease-in-out infinite;
}
@keyframes orbPulse{0%,100%{transform:translate(-50%,-50%) scale(1)}50%{transform:translate(-50%,-50%) scale(1.15)}}

.hero-eyebrow{
  font-family:var(--mono);font-size:0.7rem;letter-spacing:0.25em;
  text-transform:uppercase;color:var(--gold);
  margin-bottom:2rem;
  animation:fadeUp 0.8s 0.2s both;
  display:flex;align-items:center;gap:0.8rem;
}
.hero-eyebrow::before,.hero-eyebrow::after{
  content:'';width:30px;height:1px;background:var(--gold);opacity:0.5;
}
.hero-name{
  font-family:var(--font);
  font-size:clamp(3.5rem,12vw,11rem);
  font-weight:800;line-height:0.9;
  letter-spacing:-0.03em;
  color:var(--text);
  animation:fadeUp 0.8s 0.3s both;
  position:relative;z-index:2;
}
.hero-name .line2{
  -webkit-text-stroke:1px rgba(255,255,255,0.3);
  color:transparent;
  display:block;
}
.hero-role{
  font-family:var(--body);font-size:clamp(1rem,2vw,1.3rem);
  font-weight:300;color:var(--muted2);
  margin:1.5rem 0 0.5rem;
  animation:fadeUp 0.8s 0.4s both;
}
.hero-role strong{color:var(--gold);font-weight:500}
.hero-tagline{
  font-family:var(--mono);font-size:0.78rem;
  color:rgba(255,255,255,0.2);letter-spacing:0.1em;
  margin-bottom:3rem;
  animation:fadeUp 0.8s 0.5s both;
}

.hero-pills{
  display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;
  animation:fadeUp 0.8s 0.6s both;margin-bottom:3rem;
}
.hero-pill{
  display:inline-flex;align-items:center;gap:0.5rem;
  font-family:var(--mono);font-size:0.68rem;letter-spacing:0.12em;
  text-transform:uppercase;padding:0.5rem 1.2rem;
  border:1px solid var(--border2);color:var(--muted2);
  text-decoration:none;border-radius:2px;
  transition:all 0.3s;background:rgba(255,255,255,0.02);cursor:none;
}
.hero-pill:hover{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,0.05)}
.hero-pill svg{width:13px;height:13px}

.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:0.6rem;
  font-family:var(--mono);font-size:0.6rem;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--muted);
  animation:fadeUp 1s 1s both;
}
.scroll-line{
  width:1px;height:50px;
  background:linear-gradient(to bottom,var(--gold),transparent);
  animation:scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

/* ── SECTIONS ── */
section{scroll-margin-top:80px}
.section-wrap{max-width:1100px;margin:0 auto;padding:8rem 2rem}
.s-label{
  font-family:var(--mono);font-size:0.65rem;letter-spacing:0.25em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;
}
.s-label::after{content:'';flex:1;height:1px;background:var(--border2);max-width:80px}
.s-title{
  font-family:var(--font);
  font-size:clamp(2.5rem,6vw,5rem);
  font-weight:800;line-height:1;
  letter-spacing:-0.02em;color:var(--text);
  margin-bottom:1.5rem;
}
.s-title span{color:transparent;-webkit-text-stroke:1px rgba(255,255,255,0.25)}

/* ── ABOUT ── */
#about{background:var(--bg1)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center}
.about-bio{
  font-size:1.05rem;line-height:1.9;color:rgba(240,240,240,0.6);
  overflow-wrap:normal;word-break:normal;
}
.about-bio strong{color:var(--text);font-weight:500}
.about-bio p+p{margin-top:1.2rem}
.about-right{}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:2rem}
.stat-item{
  background:var(--bg1);padding:2rem 1.5rem;
  position:relative;overflow:hidden;
}
.stat-item::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(201,168,76,0.05),transparent);
  opacity:0;transition:opacity 0.3s;
}
.stat-item:hover::before{opacity:1}
.stat-n{
  font-family:var(--font);font-size:2.8rem;font-weight:800;
  color:var(--gold);line-height:1;display:block;
}
.stat-l{font-family:var(--mono);font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted2);margin-top:0.4rem;display:block}
.about-tags{display:flex;flex-wrap:wrap;gap:0.5rem}
.about-tag{
  font-family:var(--mono);font-size:0.65rem;letter-spacing:0.1em;
  text-transform:uppercase;padding:0.3rem 0.8rem;
  border:1px solid var(--border2);color:var(--muted2);border-radius:1px;
}

/* ── SKILLS ── */
#skills{background:var(--bg)}
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.skill-block{
  background:var(--bg);padding:2.5rem 2rem;
  position:relative;overflow:hidden;
  transition:background 0.4s;
  transform-style:preserve-3d;
}
.skill-block::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  transform:scaleX(0);transition:transform 0.4s ease;
}
.skill-block:hover{background:var(--bg2)}
.skill-block:hover::before{transform:scaleX(1)}
.skill-block-num{
  font-family:var(--mono);font-size:0.65rem;color:var(--gold);
  letter-spacing:0.15em;margin-bottom:1.5rem;
}
.skill-block-icon{font-size:2rem;margin-bottom:1rem;display:block}
.skill-block-name{
  font-family:var(--font);font-size:1rem;font-weight:700;
  color:var(--text);margin-bottom:1rem;letter-spacing:0.02em;
}
.skill-tags{display:flex;flex-wrap:wrap;gap:0.4rem}
.skill-tag{
  font-family:var(--mono);font-size:0.65rem;
  padding:0.25rem 0.6rem;border:1px solid var(--border);
  color:var(--muted2);border-radius:1px;
  transition:all 0.2s;cursor:default;
}
.skill-tag:hover{border-color:var(--gold);color:var(--gold)}

/* ── EXPERIENCE ── */
#experience{background:var(--bg1)}
.exp-list{display:flex;flex-direction:column}
.exp-row{
  display:grid;grid-template-columns:120px 1fr;gap:3rem;
  padding:3rem 0;border-bottom:1px solid var(--border);
  transition:background 0.3s;position:relative;
}
.exp-row::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:0;
  background:rgba(201,168,76,0.03);transition:width 0.4s ease;
}
.exp-row:hover::before{width:100%}
.exp-row:last-child{border-bottom:none}
.exp-num{
  font-family:var(--mono);font-size:0.65rem;
  color:var(--gold);letter-spacing:0.15em;padding-top:0.3rem;
}
.exp-period{
  font-family:var(--mono);font-size:0.65rem;
  color:var(--muted);letter-spacing:0.08em;margin-top:0.5rem;
}
.exp-company{font-family:var(--font);font-size:1.4rem;font-weight:700;color:var(--text);margin-bottom:0.3rem}
.exp-role{font-family:var(--mono);font-size:0.72rem;color:var(--gold);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem}
.exp-summary{font-size:0.95rem;color:rgba(240,240,240,0.55);line-height:1.8;margin-bottom:1.2rem}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:0.5rem}
.exp-bullets li{
  font-size:0.85rem;color:rgba(240,240,240,0.5);
  padding-left:1.5rem;position:relative;line-height:1.7;
}
.exp-bullets li::before{content:'→';position:absolute;left:0;color:var(--gold)}

/* ── PROJECTS ── */
#projects{background:var(--bg)}
.proj-grid{display:flex;flex-direction:column;gap:1px;background:var(--border)}
.proj-card{
  background:var(--bg);padding:3rem;
  display:grid;grid-template-columns:1fr auto;
  gap:3rem;align-items:start;
  position:relative;overflow:hidden;
  transition:background 0.4s;
  transform-style:preserve-3d;
  perspective:1000px;
}
.proj-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(201,168,76,0.3),transparent);
  transform:scaleX(0);transition:transform 0.5s ease;
}
.proj-card:hover{background:var(--bg2)}
.proj-card:hover::after{transform:scaleX(1)}
.proj-index{
  font-family:var(--mono);font-size:0.65rem;color:var(--gold);
  letter-spacing:0.15em;margin-bottom:1rem;
}
.proj-featured{
  display:inline-block;font-family:var(--mono);font-size:0.6rem;
  letter-spacing:0.15em;text-transform:uppercase;
  padding:0.2rem 0.6rem;border:1px solid var(--gold);
  color:var(--gold);margin-left:1rem;border-radius:1px;
  vertical-align:middle;
}
.proj-name{font-family:var(--font);font-size:1.8rem;font-weight:800;color:var(--text);margin-bottom:0.4rem;letter-spacing:-0.01em}
.proj-sub{font-family:var(--mono);font-size:0.72rem;color:var(--gold);letter-spacing:0.08em;margin-bottom:1rem}
.proj-desc{font-size:0.9rem;color:rgba(240,240,240,0.5);line-height:1.8;margin-bottom:1.5rem;max-width:600px}
.proj-stack{display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:1.2rem}
.proj-stack-tag{
  font-family:var(--mono);font-size:0.62rem;
  padding:0.2rem 0.6rem;border:1px solid var(--border);
  color:var(--muted2);border-radius:1px;
}
.proj-link{
  display:inline-flex;align-items:center;gap:0.4rem;
  font-family:var(--mono);font-size:0.68rem;letter-spacing:0.12em;
  text-transform:uppercase;color:var(--text);text-decoration:none;
  border-bottom:1px solid rgba(255,255,255,0.2);padding-bottom:2px;
  transition:color 0.3s,border-color 0.3s;cursor:none;
}
.proj-link:hover{color:var(--gold);border-color:var(--gold)}
.proj-year{font-family:var(--mono);font-size:0.7rem;color:var(--muted);letter-spacing:0.08em}

/* ── SERVICES ── */
#services{background:var(--bg1)}
.svc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border)}
.svc-card{
  background:var(--bg1);padding:3rem 2.5rem;
  position:relative;overflow:hidden;
  transition:background 0.4s;
}
.svc-card:hover{background:var(--bg2)}
.svc-card-num{font-family:var(--mono);font-size:0.65rem;color:var(--gold);letter-spacing:0.15em;margin-bottom:2rem}
.svc-icon{font-size:2.2rem;margin-bottom:1.2rem;display:block}
.svc-name{font-family:var(--font);font-size:1.2rem;font-weight:700;color:var(--text);margin-bottom:0.8rem}
.svc-desc{font-size:0.88rem;color:rgba(240,240,240,0.5);line-height:1.8}

/* ── TESTIMONIALS ── */
#testimonials{background:var(--bg);overflow:hidden;padding:8rem 0}
.testi-header{max-width:1100px;margin:0 auto;padding:0 2rem 4rem}
.marquee-wrap{overflow:hidden;position:relative}
.marquee-wrap::before,.marquee-wrap::after{
  content:'';position:absolute;top:0;bottom:0;width:150px;z-index:2;pointer-events:none;
}
.marquee-wrap::before{left:0;background:linear-gradient(to right,var(--bg),transparent)}
.marquee-wrap::after{right:0;background:linear-gradient(to left,var(--bg),transparent)}
.marquee-track{display:flex;gap:1.5rem;width:max-content;animation:marquee 35s linear infinite}
.marquee-track:hover{animation-play-state:paused}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@media(prefers-reduced-motion:reduce){.marquee-track{animation:none;overflow-x:auto}}
.testi-card{
  background:var(--bg2);border:1px solid var(--border);
  padding:2rem;width:340px;flex-shrink:0;border-radius:2px;
  transition:border-color 0.3s;
}
.testi-card:hover{border-color:rgba(201,168,76,0.3)}
.testi-quote{
  font-size:0.9rem;font-style:italic;
  color:rgba(240,240,240,0.6);line-height:1.8;margin-bottom:1.5rem;
  position:relative;padding-left:1rem;
  border-left:2px solid var(--gold);
}
.testi-author{display:flex;align-items:center;gap:0.8rem}
.testi-av{
  width:38px;height:38px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--font);font-size:0.9rem;font-weight:700;color:#000;
  flex-shrink:0;
}
.testi-name{font-family:var(--font);font-size:0.85rem;font-weight:700;letter-spacing:0.05em}
.testi-role{font-family:var(--mono);font-size:0.65rem;color:var(--muted2);margin-top:0.1rem}

/* ── CONTACT ── */
#contact{background:var(--bg1)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start}
.contact-left{}
.contact-info{display:flex;flex-direction:column;gap:1.5rem;margin-top:2.5rem}
.contact-item{
  display:flex;align-items:flex-start;gap:1rem;
  padding:1.5rem;border:1px solid var(--border);
  background:var(--bg);transition:border-color 0.3s;
}
.contact-item:hover{border-color:rgba(201,168,76,0.3)}
.contact-item-icon{font-size:1.2rem;flex-shrink:0;margin-top:0.1rem}
.contact-item-label{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold);margin-bottom:0.3rem}
.contact-item-val{font-size:0.9rem;color:rgba(240,240,240,0.7)}
.contact-form{display:flex;flex-direction:column;gap:1.2rem}
.form-group{display:flex;flex-direction:column;gap:0.4rem}
.form-label{font-family:var(--mono);font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted2)}
.form-input,.form-textarea{
  background:var(--bg);border:1px solid var(--border);
  color:var(--text);font-family:var(--body);font-size:0.92rem;
  padding:0.9rem 1rem;outline:none;border-radius:1px;
  transition:border-color 0.3s;
}
.form-input:focus,.form-textarea:focus{border-color:var(--gold)}
.form-textarea{min-height:140px;resize:vertical}
.btn{
  display:inline-flex;align-items:center;gap:0.6rem;
  font-family:var(--mono);font-size:0.72rem;letter-spacing:0.15em;
  text-transform:uppercase;padding:1rem 2.5rem;
  background:var(--gold);color:#000;border:none;
  cursor:none;transition:all 0.3s;font-weight:500;
  position:relative;overflow:hidden;
}
.btn::before{
  content:'';position:absolute;inset:0;
  background:rgba(0,0,0,0.1);transform:translateX(-100%);
  transition:transform 0.3s;
}
.btn:hover::before{transform:translateX(0)}
.btn:hover{background:var(--gold2)}

/* ── FOOTER ── */
footer{
  background:var(--bg);
  border-top:1px solid var(--border);
  padding:4rem 2rem 2rem;
}
.footer-inner{max-width:1100px;margin:0 auto}
.footer-top{
  display:grid;grid-template-columns:2fr 1fr 1fr;gap:4rem;
  padding-bottom:3rem;border-bottom:1px solid var(--border);
}
.footer-brand-name{
  font-family:var(--font);font-size:1.4rem;font-weight:800;
  color:var(--text);margin-bottom:0.5rem;letter-spacing:0.02em;
}
.footer-brand-name span{color:var(--gold)}
.footer-brand-sub{font-family:var(--mono);font-size:0.65rem;letter-spacing:0.1em;color:var(--muted2);margin-bottom:0.3rem}
.footer-col-label{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-bottom:1.2rem}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:0.7rem}
.footer-links a{font-size:0.88rem;color:rgba(240,240,240,0.5);text-decoration:none;transition:color 0.2s}
.footer-links a:hover{color:var(--gold)}
.footer-reach{display:flex;flex-direction:column;gap:0.6rem}
.footer-reach a{font-family:var(--mono);font-size:0.72rem;color:var(--gold);text-decoration:none;transition:opacity 0.2s}
.footer-reach a:hover{opacity:0.7}
.footer-bottom{
  display:flex;justify-content:space-between;align-items:center;
  padding-top:2rem;font-family:var(--mono);font-size:0.65rem;
  color:var(--muted);letter-spacing:0.08em;
}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(50px);transition:opacity 0.8s cubic-bezier(0.22,1,0.36,1),transform 0.8s cubic-bezier(0.22,1,0.36,1)}
.reveal.from-left{transform:translateX(-50px)}
.reveal.from-right{transform:translateX(50px)}
.reveal.visible{opacity:1;transform:translate(0)}
.d1{transition-delay:0.1s}.d2{transition-delay:0.2s}.d3{transition-delay:0.3s}.d4{transition-delay:0.4s}.d5{transition-delay:0.5s}

/* ── 3D TILT ── */
.tilt{transform-style:preserve-3d;will-change:transform}
